              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"@WindahBatubara\",\n  \"max_videos\": 10,\n  \"dataset_name\": \"Channel Explorer Dataset\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/explorer/channel/run",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "explorer", "channel", "run"]
            }
          }
        }
      ]
    }
  ]
}
