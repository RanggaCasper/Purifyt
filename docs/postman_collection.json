          "name": "Reset Manual Label",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Reset label manual ke null (kembali hanya pakai predicted_label).",
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/comment/1/label",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "comment", "1", "label"]
            }
          }
        },
        {
          "name": "Bulk Manual Label (Dataset)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"labels\": [\n    { \"comment_id\": 1, \"label\": \"1\" },\n    { \"comment_id\": 2, \"label\": \"0\" },\n    { \"comment_id\": 3, \"label\": \"1\" }\n  ]\n}"
            },
            "description": "Koreksi label manual untuk banyak comment sekaligus dalam satu dataset.",
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/dataset/1/bulk",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "dataset", "1", "bulk"]
