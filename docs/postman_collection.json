    {
      "name": "Auto Delete",
      "description": "Browser automation for scanning and deleting gambling comments via YouTube Studio. All SSE endpoints stream real-time events.",
      "item": [
        {
          "name": "Login Google Account (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your-youtube-account@gmail.com\",\n  \"password\": \"your-password\",\n  \"headless\": true,\n  \"timeout\": 120\n}"
            },
            "description": "Auto-login ke akun Google dan simpan cookie YouTube Studio.\n\nSSE events:\n- status — progress (browser, input_email, input_password, verify, save)\n- done   — {logged_in, email, channel_name, cookies_saved, cookie_count, cookie_path}\n- error  — error message",
            "url": {
              "raw": "{{base_url}}/api/v1/auto-delete/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auto-delete", "login"]
            }
          }
        },
        {
          "name": "Scan & Delete Gambling Comments (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"dQw4w9WgXcQ\",\n  \"email\": \"your-youtube-account@gmail.com\",\n  \"threshold\": 0.7,\n  \"headless\": true\n}"
            },
            "description": "Scan video dan langsung hapus komentar judi yang terdeteksi.\n\nSSE events:\n- status        — progress\n- comment       — safe comment\n- judi_detected — gambling comment found\n- delete        — deletion result\n- done          — final summary\n- error         — error",
            "url": {
              "raw": "{{base_url}}/api/v1/auto-delete/scan",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auto-delete", "scan"]
            }
          }
        },
        {
          "name": "Scan Preview / Dry Run (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"dQw4w9WgXcQ\",\n  \"email\": \"your-youtube-account@gmail.com\",\n  \"threshold\": 0.7,\n  \"headless\": true\n}"
            },
            "description": "Scan video tanpa menghapus (dry-run). Preview komentar judi yang akan dihapus.",
            "url": {
              "raw": "{{base_url}}/api/v1/auto-delete/scan/preview",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auto-delete", "scan", "preview"]
            }
          }
        },
        {
          "name": "Delete Specific Comments (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"dQw4w9WgXcQ\",\n  \"email\": \"your-youtube-account@gmail.com\",\n  \"comment_ids\": [\"UgxABC123\", \"UgxDEF456\"],\n  \"headless\": true\n}"
            },
            "description": "Hapus komentar spesifik berdasarkan comment ID.\n\nSSE events:\n- status — progress\n- done   — {deleted, requested, message}\n- error  — error message",
            "url": {
              "raw": "{{base_url}}/api/v1/auto-delete/delete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auto-delete", "delete"]
            }
          }
        },
        {
          "name": "Fetch Video Comments from Studio (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"dQw4w9WgXcQ\",\n  \"email\": \"your-youtube-account@gmail.com\",\n  \"headless\": true\n}"
            },
            "description": "Ambil semua komentar dari YouTube Studio tanpa scan ML.\n\nSSE events:\n- status — progress\n- done   — {video_id, total, comments, message}\n- error  — error message",
            "url": {
              "raw": "{{base_url}}/api/v1/auto-delete/comments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auto-delete", "comments"]
            }
          }
        },
        {
          "name": "List Cookie Accounts",
          "request": {
            "method": "GET",
            "header": [
