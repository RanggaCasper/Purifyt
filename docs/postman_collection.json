    {
      "name": "Labeling",
      "item": [
        {
          "name": "Predict Single Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"slot gacor hari ini maxwin bos\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/predict",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "predict"]
            }
          }
        },
        {
          "name": "Predict Batch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"texts\": [\n    \"slot gacor hari ini\",\n    \"videonya bagus banget kak\",\n    \"link slot deposit 10rb\",\n    \"semoga sukses terus\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/predict/batch",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "predict", "batch"]
            }
          }
        },
        {
          "name": "Auto-Label Dataset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Auto-label all comments in a dataset using the ML model.",
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/dataset/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "dataset", "1"]
            }
          }
        },
        {
          "name": "Manual Label Comment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"1\"\n}"
            },
            "description": "Koreksi label manual: \"0\" = non judi, \"1\" = judi online.",
            "url": {
              "raw": "{{base_url}}/api/v1/labeling/comment/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "labeling", "comment", "1"]
            }
          }
        },
