{
  "productName": "Purifyt",
  "version": "1.0.1",
  "identifier": "com.purifyt.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:server && pnpm generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "Purifyt",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/purifyt-server"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
