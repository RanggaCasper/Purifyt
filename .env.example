# App 
APP_NAME="Purifyt - YouTube Comment Dataset API"
APP_VERSION="1.0.0"
DEBUG=true  # false in production

# MySQL 
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=purifyt

# YouTube Data API v3 
YOUTUBE_API_KEY=

# Kaggle 
KAGGLE_USERNAME=
KAGGLE_KEY=

# JWT / Authentication 
# IMPORTANT: Generate a strong random key for production!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15          # Short-lived (10–15 min recommended)
REFRESH_TOKEN_EXPIRE_DAYS=7             # Long-lived  (7–30 days)

# Cookie Settings 
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
COOKIE_DOMAIN=

# CORS 
# JSON array of allowed origins. NEVER use "*" when allow_credentials=true.
CORS_ORIGINS=["http://localhost:3000"]
# Production example:
# CORS_ORIGINS=["https://app.yourdomain.com"]
